{
  "name": "ai-learning-game-starter",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "netlify dev",
    "dev:vite": "vite",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.functions.json --noEmit",
    "build": "npm run typecheck && vite build",
    "test": "vitest run",
    "test:integration": "tsx tests/functions.integration.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx database/migrate.ts",
    "db:seed": "tsx database/seed.ts",
    "db:reset": "tsx database/reset.ts"
  },
  "dependencies": {
    "@netlify/functions": "^3.1.10",
    "drizzle-orm": "^0.44.2",
    "openai": "^5.8.2",
    "postgres": "^3.4.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.32",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "drizzle-kit": "^0.31.1",
    "jsdom": "^26.1.0",
    "netlify-cli": "^23.1.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
