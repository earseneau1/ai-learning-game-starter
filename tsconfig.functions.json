{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["netlify/functions/**/*.ts", "database/**/*.ts", "src/types/**/*.ts", "src/game-content/**/*.ts", "src/game-engine/logic.ts"]
}
